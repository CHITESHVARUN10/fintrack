# --- Database ---
mongo_uri=mongodb://localhost:27017/fintrack
MONGODB_URI=mongodb://localhost:27017/fintrack

# --- Server ---
PORT=5000
SESSION_SECRET=change-me-to-a-long-random-string

# --- AI (Google Gemini) ---
# Get a key at https://aistudio.google.com/apikey
# Required for live Form 16 extraction & tax recommendations.
# Leave as the placeholder to use built-in mock fallbacks in dev.
GEMINI_API_KEY=your-gemini-api-key

# --- CORS ---
# Comma-separated allowed origins. Defaults to allowing all if omitted.
CORS_ORIGIN=http://localhost:5173

# --- Email (SMTP, optional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-app-password
EMAIL_FROM="FinTrack" <noreply@example.com>
